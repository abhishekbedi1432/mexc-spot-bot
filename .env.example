# Copy to .env and fill in values. Never commit .env.

# Binance API credentials (read-only for Phases 0-4; add TRADE permission for Phase 5+)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Master dry-run switch. Set to "false" only when ready for live trading (Phase 6+)
DRY_RUN=true

# Starting capital in USDT
CAPITAL_USDT=10.0
